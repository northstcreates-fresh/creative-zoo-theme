{%- liquid
  assign mode_class = 'cz-surface--light'
  if section.settings.mode == 'dark'
    assign mode_class = 'cz-surface--dark'
  endif
  assign texture_class = ''
  if section.settings.texture_enabled
    assign texture_class = 'cz-texture cz-texture--' | append: section.settings.texture_style
  endif
  assign overlay_color = section.settings.overlay_color | default: '#111111'
-%}

{%- style -%}
  .section-{{ section.id }} {
    --cz-section-bg: {{ section.settings.background_color | default: settings.cz_primary_background }};
    --cz-section-text: {{ section.settings.text_color | default: settings.cz_primary_text }};
    --cz-section-accent: {{ section.settings.accent_color | default: settings.cz_accent_color }};
    --cz-section-button: {{ section.settings.button_color | default: settings.cz_button_color }};
    --cz-section-button-text: {{ section.settings.button_text_color | default: settings.cz_button_text_color }};
    --cz-texture-opacity: {{ section.settings.texture_opacity | divided_by: 100.0 }};
    --cz-hero-overlay-color: {{ overlay_color }};
    --cz-hero-overlay-rgb: {{ overlay_color.red }}, {{ overlay_color.green }}, {{ overlay_color.blue }};
    --cz-hero-overlay-opacity: {{ section.settings.overlay_opacity_mobile | divided_by: 100.0 }};
    --cz-hero-overlay-opacity-desktop: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    min-height: {{ section.settings.height_mobile }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} {
      --cz-hero-overlay-opacity: var(--cz-hero-overlay-opacity-desktop);
      min-height: {{ section.settings.height_desktop }}px;
    }
  }
{%- endstyle -%}

<section class="cz-hero-ecosystem cz-surface {{ mode_class }} {{ texture_class }} section-{{ section.id }}">
  <div class="cz-hero-ecosystem__media" aria-hidden="true">
    {%- if section.settings.video != blank -%}
      {{ section.settings.video | video_tag: autoplay: true, loop: true, muted: true, controls: false, image_size: '1800x' }}
    {%- elsif section.settings.image != blank -%}
      {{
        section.settings.image
        | image_url: width: 2400
        | image_tag:
          loading: 'eager',
          widths: '750, 1100, 1500, 1800, 2200, 2400',
          sizes: '100vw',
          alt: section.settings.image_alt,
          class: 'cz-hero-ecosystem__image'
      }}
    {%- endif -%}
  </div>
  <div class="cz-hero-ecosystem__overlay{% if section.settings.gradient_overlay_enabled %} cz-hero-ecosystem__overlay--gradient{% endif %}"></div>

  <div class="page-width cz-hero-ecosystem__inner">
    {%- if section.settings.eyebrow != blank -%}
      <p class="cz-section-kicker">{{ section.settings.eyebrow | escape }}</p>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h1 class="cz-section-heading">{{ section.settings.heading | escape }}</h1>
    {%- endif -%}
    {%- if section.settings.text != blank -%}
      <div class="cz-section-copy rte">{{ section.settings.text }}</div>
    {%- endif -%}
    {%- if section.settings.button_label != blank or section.settings.secondary_button_label != blank -%}
      <div class="cz-hero-ecosystem__buttons">
        {%- if section.settings.button_label != blank -%}
          <a class="cz-visual-button" {% if section.settings.button_link == blank %}role="link" aria-disabled="true"{% else %}href="{{ section.settings.button_link }}"{% endif %}>
            {{ section.settings.button_label | escape }}
          </a>
        {%- endif -%}
        {%- if section.settings.secondary_button_label != blank -%}
          <a class="cz-visual-button cz-visual-button--secondary" {% if section.settings.secondary_button_link == blank %}role="link" aria-disabled="true"{% else %}href="{{ section.settings.secondary_button_link }}"{% endif %}>
            {{ section.settings.secondary_button_label | escape }}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .cz-hero-ecosystem {
    display: flex;
    align-items: end;
    overflow: hidden;
  }
  .cz-hero-ecosystem__media,
  .cz-hero-ecosystem__overlay {
    position: absolute;
    inset: 0;
  }
  .cz-hero-ecosystem__media {
    z-index: -1;
    background: var(--cz-black);
  }
  .cz-hero-ecosystem__media img,
  .cz-hero-ecosystem__media video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .cz-hero-ecosystem__overlay {
    z-index: 0;
    background: var(--cz-hero-overlay-color, var(--cz-black));
    opacity: var(--cz-hero-overlay-opacity);
  }
  .cz-hero-ecosystem__overlay--gradient {
    opacity: 1;
    background: linear-gradient(
      90deg,
      rgba(var(--cz-hero-overlay-rgb, 17, 17, 17), var(--cz-hero-overlay-opacity)) 0%,
      rgba(var(--cz-hero-overlay-rgb, 17, 17, 17), calc(var(--cz-hero-overlay-opacity) * 0.82)) 38%,
      rgba(var(--cz-hero-overlay-rgb, 17, 17, 17), calc(var(--cz-hero-overlay-opacity) * 0.32)) 100%
    );
  }
  .cz-hero-ecosystem__inner {
    position: relative;
    z-index: 1;
    width: 100%;
    padding-block: clamp(6rem, 10vw, 12rem);
  }
  .cz-hero-ecosystem .cz-section-heading {
    max-width: 12ch;
    font-size: clamp(5rem, 10vw, 12rem);
  }
  .cz-hero-ecosystem__buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 3rem;
  }
  .cz-visual-button--secondary {
    background: transparent;
    color: currentColor;
    box-shadow: inset 0 0 0 1px currentColor;
  }
  .cz-hero-ecosystem .cz-visual-button--secondary {
    border-color: currentColor;
  }
  @media screen and (max-width: 749px) {
    .cz-hero-ecosystem__overlay--gradient {
      background: linear-gradient(
        180deg,
        rgba(var(--cz-hero-overlay-rgb, 17, 17, 17), calc(var(--cz-hero-overlay-opacity) * 0.78)) 0%,
        rgba(var(--cz-hero-overlay-rgb, 17, 17, 17), var(--cz-hero-overlay-opacity)) 62%,
        rgba(var(--cz-hero-overlay-rgb, 17, 17, 17), calc(var(--cz-hero-overlay-opacity) * 0.9)) 100%
      );
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "CZ hero ecosystem",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Creative Zoo" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "The Wildest Thing You Can Be Is Yourself." },
    { "type": "richtext", "id": "text", "label": "Body text", "default": "<p>A creative ecosystem for people who refuse to tuck away what makes them different.</p>" },
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "image_alt", "label": "Image alt text" },
    { "type": "video", "id": "video", "label": "Video" },
    { "type": "text", "id": "button_label", "label": "CTA text", "default": "Enter The Habitat" },
    { "type": "url", "id": "button_link", "label": "CTA link" },
    { "type": "text", "id": "secondary_button_label", "label": "Secondary CTA text" },
    { "type": "url", "id": "secondary_button_link", "label": "Secondary CTA link" },
    { "type": "select", "id": "mode", "label": "Mode", "options": [{ "value": "light", "label": "Light" }, { "value": "dark", "label": "Dark" }], "default": "dark" },
    { "type": "color", "id": "background_color", "label": "Background" },
    { "type": "color", "id": "text_color", "label": "Text" },
    { "type": "color", "id": "accent_color", "label": "Accent" },
    { "type": "color", "id": "button_color", "label": "Button" },
    { "type": "color", "id": "button_text_color", "label": "Button text" },
    { "type": "color", "id": "overlay_color", "label": "Overlay color", "default": "#111111" },
    { "type": "checkbox", "id": "gradient_overlay_enabled", "label": "Use gradient overlay", "default": true },
    { "type": "range", "id": "overlay_opacity", "min": 0, "max": 90, "step": 5, "unit": "%", "label": "Overlay opacity", "default": 40 },
    { "type": "range", "id": "overlay_opacity_mobile", "min": 0, "max": 90, "step": 5, "unit": "%", "label": "Mobile overlay opacity", "default": 55 },
    { "type": "checkbox", "id": "texture_enabled", "label": "Texture overlay", "default": false },
    { "type": "select", "id": "texture_style", "label": "Texture style", "options": [{ "value": "paper", "label": "Paper grain" }, { "value": "fabric", "label": "Fabric" }, { "value": "sketch", "label": "Sketch" }], "default": "paper" },
    { "type": "range", "id": "texture_opacity", "min": 0, "max": 10, "step": 1, "unit": "%", "label": "Texture opacity", "default": 4 },
    { "type": "range", "id": "height_desktop", "min": 520, "max": 900, "step": 20, "unit": "px", "label": "Desktop height", "default": 760 },
    { "type": "range", "id": "height_mobile", "min": 420, "max": 760, "step": 20, "unit": "px", "label": "Mobile height", "default": 560 }
  ],
  "presets": [{ "name": "CZ hero ecosystem" }]
}
{% endschema %}
