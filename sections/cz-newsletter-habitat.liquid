{%- liquid
  assign mode_class = 'cz-surface--light'
  if section.settings.mode == 'dark'
    assign mode_class = 'cz-surface--dark'
  endif
  assign texture_class = ''
  if section.settings.texture_enabled
    assign texture_class = 'cz-texture cz-texture--' | append: section.settings.texture_style
  endif
-%}

{%- style -%}
  .section-{{ section.id }} {
    --cz-section-bg: {{ section.settings.background_color | default: settings.cz_primary_background }};
    --cz-section-text: {{ section.settings.text_color | default: settings.cz_primary_text }};
    --cz-section-accent: {{ section.settings.accent_color | default: settings.cz_accent_color }};
    --cz-section-button: {{ section.settings.button_color | default: settings.cz_button_color }};
    --cz-section-button-text: {{ section.settings.button_text_color | default: settings.cz_button_text_color }};
    --cz-texture-opacity: {{ section.settings.texture_opacity | divided_by: 100.0 }};
    padding-block: {{ section.settings.padding_top | times: 0.75 | round }}px {{ section.settings.padding_bottom | times: 0.75 | round }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }} { padding-block: {{ section.settings.padding_top }}px {{ section.settings.padding_bottom }}px; }
  }
{%- endstyle -%}

<section class="cz-newsletter-habitat cz-surface {{ mode_class }} {{ texture_class }} section-{{ section.id }}">
  <div class="page-width cz-newsletter-habitat__inner">
    <div class="cz-newsletter-habitat__content">
      {%- if section.settings.eyebrow != blank -%}<p class="cz-section-kicker">{{ section.settings.eyebrow | escape }}</p>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h2 class="cz-section-heading">{{ section.settings.heading | escape }}</h2>{%- endif -%}
      {%- if section.settings.text != blank -%}<div class="cz-section-copy rte">{{ section.settings.text }}</div>{%- endif -%}
      {% form 'customer', class: 'cz-newsletter-habitat__form' %}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <div class="cz-newsletter-habitat__field">
          <label class="visually-hidden" for="NewsletterForm--{{ section.id }}">{{ section.settings.email_label | escape }}</label>
          <input id="NewsletterForm--{{ section.id }}" type="email" name="contact[email]" value="{{ form.email }}" aria-required="true" autocorrect="off" autocapitalize="off" autocomplete="email" placeholder="{{ section.settings.email_label | escape }}" required>
          <button type="submit" class="cz-visual-button" name="commit">{{ section.settings.button_label | escape }}</button>
        </div>
        {%- if form.errors -%}<small class="newsletter-form__message form__message">{{ form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email }}</small>{%- endif -%}
        {%- if form.posted_successfully? -%}<h3 class="newsletter-form__message newsletter-form__message--success form__message" tabindex="-1" autofocus>{{ section.settings.success_text | escape }}</h3>{%- endif -%}
      {% endform %}
    </div>
    <div class="cz-newsletter-habitat__media cz-visual-media">
      {%- if section.settings.video != blank -%}
        {{ section.settings.video | video_tag: autoplay: true, loop: true, muted: true, controls: false, image_size: '1200x' }}
      {%- elsif section.settings.image != blank -%}
        {{ section.settings.image | image_url: width: 1400 | image_tag: loading: 'lazy', widths: '550, 750, 1100, 1400', sizes: '(min-width: 990px) 38vw, 100vw', alt: section.settings.image_alt }}
      {%- else -%}
        {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
      {%- endif -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .cz-newsletter-habitat__inner { display: grid; grid-template-columns: minmax(28rem, 1fr) minmax(0, 0.7fr); gap: clamp(2rem, 5vw, 6rem); align-items: center; }
  .cz-newsletter-habitat__media { min-height: 28rem; aspect-ratio: 4 / 3; }
  .cz-newsletter-habitat__form { margin-top: 3rem; }
  .cz-newsletter-habitat__field { display: flex; gap: 1rem; max-width: 64rem; }
  .cz-newsletter-habitat__field input { flex: 1; min-height: 5.2rem; border: 1px solid currentColor; background: transparent; color: currentColor; padding: 0 1.6rem; font: inherit; }
  .cz-newsletter-habitat__field input::placeholder { color: var(--cz-section-muted); opacity: 1; }
  @media screen and (max-width: 989px) {
    .cz-newsletter-habitat__inner { grid-template-columns: 1fr; }
    .cz-newsletter-habitat__field { flex-direction: column; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "CZ newsletter habitat",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Join" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Join The Habitat" },
    { "type": "richtext", "id": "text", "label": "Body text", "default": "<p>Get first access to drops, story releases, field notes, and community signals.</p>" },
    { "type": "text", "id": "email_label", "label": "Email placeholder", "default": "Email address" },
    { "type": "text", "id": "button_label", "label": "Button text", "default": "Join" },
    { "type": "text", "id": "success_text", "label": "Success message", "default": "Welcome to the Habitat." },
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "image_alt", "label": "Image alt text" },
    { "type": "video", "id": "video", "label": "Video" },
    { "type": "select", "id": "mode", "label": "Mode", "options": [{ "value": "light", "label": "Light" }, { "value": "dark", "label": "Dark" }], "default": "light" },
    { "type": "color", "id": "background_color", "label": "Background" },
    { "type": "color", "id": "text_color", "label": "Text" },
    { "type": "color", "id": "accent_color", "label": "Accent" },
    { "type": "color", "id": "button_color", "label": "Button" },
    { "type": "color", "id": "button_text_color", "label": "Button text" },
    { "type": "checkbox", "id": "texture_enabled", "label": "Texture overlay", "default": false },
    { "type": "select", "id": "texture_style", "label": "Texture style", "options": [{ "value": "paper", "label": "Paper grain" }, { "value": "fabric", "label": "Fabric" }, { "value": "sketch", "label": "Sketch" }], "default": "paper" },
    { "type": "range", "id": "texture_opacity", "min": 0, "max": 10, "step": 1, "unit": "%", "label": "Texture opacity", "default": 3 },
    { "type": "range", "id": "padding_top", "min": 0, "max": 140, "step": 4, "unit": "px", "label": "Top padding", "default": 88 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 140, "step": 4, "unit": "px", "label": "Bottom padding", "default": 88 }
  ],
  "presets": [{ "name": "CZ newsletter habitat" }]
}
{% endschema %}
