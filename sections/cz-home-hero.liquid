{%- style -%}
  .section-{{ section.id }} {
    --cz-hero-text: {{ section.settings.text_color }};
    --cz-hero-overlay: {{ section.settings.overlay_color }};
    --cz-hero-overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    --cz-hero-min-height: {{ section.settings.min_height_mobile }}px;
    --cz-hero-media-fit: {{ section.settings.media_fit }};
    --cz-hero-media-position: {{ section.settings.mobile_media_position }};
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} {
      --cz-hero-min-height: {{ section.settings.min_height_desktop }}px;
      --cz-hero-media-position: {{ section.settings.media_position }};
    }
  }
{%- endstyle -%}

<section class="cz-home-hero section-{{ section.id }}">
  <div class="cz-home-hero__media" aria-hidden="true">
    {%- if section.settings.video != blank -%}
      {{ section.settings.video | video_tag: autoplay: section.settings.video_autoplay, loop: section.settings.video_loop, muted: section.settings.video_muted, playsinline: true, controls: false, image_size: '1800x' }}
    {%- elsif section.settings.image != blank -%}
      {{
        section.settings.image
        | image_url: width: 2400
        | image_tag:
          loading: 'eager',
          widths: '750, 1100, 1500, 1780, 2000, 2400',
          sizes: '100vw',
          class: 'cz-home-hero__image'
      }}
    {%- else -%}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg cz-home-hero__placeholder' }}
    {%- endif -%}
  </div>

  <div class="cz-home-hero__overlay"></div>

  <div class="cz-home-hero__content page-width">
    {%- if section.settings.eyebrow != blank -%}
      <p class="cz-home-hero__eyebrow">{{ section.settings.eyebrow | escape }}</p>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h1 class="cz-home-hero__heading">{{ section.settings.heading | escape }}</h1>
    {%- endif -%}

    {%- if section.settings.subheading != blank -%}
      <div class="cz-home-hero__subheading rte">{{ section.settings.subheading }}</div>
    {%- endif -%}

    <div class="cz-home-hero__buttons">
      {%- for block in section.blocks -%}
        {%- if block.type == 'button' and block.settings.label != blank -%}
          <a
            class="button{% if block.settings.style == 'secondary' %} button--secondary{% else %} button--primary{% endif %}"
            {% if block.settings.link == blank %}
              role="link" aria-disabled="true"
            {% else %}
              href="{{ block.settings.link }}"
            {% endif %}
            {{ block.shopify_attributes }}
          >
            {{ block.settings.label | escape }}
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .cz-home-hero {
    position: relative;
    isolation: isolate;
    display: flex;
    min-height: var(--cz-hero-min-height);
    align-items: end;
    overflow: hidden;
    color: var(--cz-hero-text);
  }

  .cz-home-hero__media,
  .cz-home-hero__overlay {
    position: absolute;
    inset: 0;
  }

  .cz-home-hero__media video,
  .cz-home-hero__image,
  .cz-home-hero__placeholder {
    width: 100%;
    height: 100%;
    object-fit: var(--cz-hero-media-fit, cover);
    object-position: var(--cz-hero-media-position, center center);
  }

  .cz-home-hero__overlay {
    z-index: -1;
    background: var(--cz-hero-overlay);
    opacity: var(--cz-hero-overlay-opacity);
  }

  .cz-home-hero__media {
    z-index: -2;
    background: #121212;
  }

  .cz-home-hero__content {
    width: 100%;
    padding-block: clamp(5.6rem, 8vw, 10rem);
  }

  .cz-home-hero__eyebrow {
    margin: 0 0 1.4rem;
    max-width: 64rem;
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .cz-home-hero__heading {
    max-width: 12ch;
    margin: 0;
    color: currentColor;
    font-family: var(--font-heading-family);
    font-size: clamp(4.2rem, 9vw, 10.5rem);
    line-height: 0.9;
    letter-spacing: 0;
  }

  .cz-home-hero__subheading {
    max-width: 64rem;
    margin-top: 2.2rem;
    font-size: clamp(1.7rem, 2vw, 2.3rem);
    line-height: 1.45;
  }

  .cz-home-hero__buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 1.2rem;
    margin-top: 3rem;
  }

  @media screen and (max-width: 749px) {
    .cz-home-hero__buttons {
      flex-direction: column;
    }

    .cz-home-hero__buttons .button {
      width: 100%;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "CZ home hero",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Creative Zoo"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Headline",
      "default": "The Wildest Thing You Can Be Is Yourself."
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subheadline",
      "default": "<p>Creative Zoo is a creative ecosystem built for people who refuse to tuck away what makes them different. Through apparel, stories, music, and imagination, we celebrate the instinct to create, explore, and become something uniquely your own.</p>"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Background video"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Fallback image"
    },
    {
      "type": "select",
      "id": "media_fit",
      "label": "Media fit",
      "options": [
        { "value": "cover", "label": "Cover" },
        { "value": "contain", "label": "Contain" },
        { "value": "fill", "label": "Fill" }
      ],
      "default": "cover"
    },
    {
      "type": "select",
      "id": "media_position",
      "label": "Desktop media focal point",
      "options": [
        { "value": "center center", "label": "Center center" },
        { "value": "top center", "label": "Top center" },
        { "value": "bottom center", "label": "Bottom center" },
        { "value": "left center", "label": "Left center" },
        { "value": "right center", "label": "Right center" }
      ],
      "default": "center center"
    },
    {
      "type": "select",
      "id": "mobile_media_position",
      "label": "Mobile media focal point",
      "options": [
        { "value": "center center", "label": "Center center" },
        { "value": "top center", "label": "Top center" },
        { "value": "bottom center", "label": "Bottom center" },
        { "value": "left center", "label": "Left center" },
        { "value": "right center", "label": "Right center" }
      ],
      "default": "center center"
    },
    {
      "type": "checkbox",
      "id": "video_autoplay",
      "label": "Autoplay video",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "video_muted",
      "label": "Mute video by default",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "video_loop",
      "label": "Loop video",
      "default": true
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#121212"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 90,
      "step": 5,
      "unit": "%",
      "label": "Overlay opacity",
      "default": 35
    },
    {
      "type": "range",
      "id": "min_height_desktop",
      "min": 520,
      "max": 900,
      "step": 20,
      "unit": "px",
      "label": "Desktop height",
      "default": 760
    },
    {
      "type": "range",
      "id": "min_height_mobile",
      "min": 420,
      "max": 760,
      "step": 20,
      "unit": "px",
      "label": "Mobile height",
      "default": 560
    }
  ],
  "blocks": [
    {
      "type": "button",
      "name": "CTA button",
      "limit": 3,
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Shop apparel"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "select",
          "id": "style",
          "label": "Style",
          "options": [
            {
              "value": "primary",
              "label": "Primary"
            },
            {
              "value": "secondary",
              "label": "Secondary"
            }
          ],
          "default": "primary"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "CZ home hero",
      "blocks": [
        {
          "type": "button"
        },
        {
          "type": "button",
          "settings": {
            "label": "Explore the habitat",
            "style": "secondary"
          }
        }
      ]
    }
  ]
}
{% endschema %}
