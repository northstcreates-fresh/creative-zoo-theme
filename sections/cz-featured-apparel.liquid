{%- liquid
  assign mode_class = 'cz-surface--light'
  if section.settings.mode == 'dark'
    assign mode_class = 'cz-surface--dark'
  endif
  assign texture_class = ''
  if section.settings.texture_enabled
    assign texture_class = 'cz-texture cz-texture--' | append: section.settings.texture_style
  endif
-%}

{%- style -%}
  .section-{{ section.id }} {
    --cz-section-bg: {{ section.settings.background_color | default: settings.cz_primary_background }};
    --cz-section-text: {{ section.settings.text_color | default: settings.cz_primary_text }};
    --cz-section-card: {{ section.settings.card_color | default: settings.cz_card_background }};
    --cz-section-accent: {{ section.settings.accent_color | default: settings.cz_accent_color }};
    --cz-section-button: {{ section.settings.button_color | default: settings.cz_button_color }};
    --cz-section-button-text: {{ section.settings.button_text_color | default: settings.cz_button_text_color }};
    --cz-texture-opacity: {{ section.settings.texture_opacity | divided_by: 100.0 }};
    padding-block: {{ section.settings.padding_top | times: 0.75 | round }}px {{ section.settings.padding_bottom | times: 0.75 | round }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }} { padding-block: {{ section.settings.padding_top }}px {{ section.settings.padding_bottom }}px; }
  }
{%- endstyle -%}

<section class="cz-featured-apparel cz-surface {{ mode_class }} {{ texture_class }} section-{{ section.id }}">
  <div class="page-width">
    <div class="cz-featured-apparel__header">
      <div>
        {%- if section.settings.eyebrow != blank -%}<p class="cz-section-kicker">{{ section.settings.eyebrow | escape }}</p>{%- endif -%}
        {%- if section.settings.heading != blank -%}<h2 class="cz-section-heading">{{ section.settings.heading | escape }}</h2>{%- endif -%}
        {%- if section.settings.text != blank -%}<div class="cz-section-copy rte">{{ section.settings.text }}</div>{%- endif -%}
      </div>
      {%- if section.settings.button_label != blank -%}
        <a class="cz-visual-button" {% if section.settings.button_link == blank %}role="link" aria-disabled="true"{% else %}href="{{ section.settings.button_link }}"{% endif %}>{{ section.settings.button_label | escape }}</a>
      {%- endif -%}
    </div>

    <div class="cz-featured-apparel__grid">
      {%- for block in section.blocks -%}
        {%- liquid
          assign collection = block.settings.collection
          assign title = block.settings.fallback_title
          if collection != blank and collection.title != blank
            assign title = collection.title
          endif
          assign description = block.settings.fallback_text
          if collection != blank and collection.description != blank
            assign description = collection.description
          endif
          assign link = block.settings.fallback_link
          if collection != blank
            assign link = collection.url
          endif
          assign image = block.settings.image
          if image == blank and collection != blank
            assign image = collection.image
          endif
        -%}
        <article class="cz-visual-card cz-featured-apparel__card" {{ block.shopify_attributes }}>
          <a class="cz-featured-apparel__media cz-visual-media" {% if link == blank %}role="link" aria-disabled="true"{% else %}href="{{ link }}"{% endif %}>
            {%- if block.settings.video != blank -%}
              {{ block.settings.video | video_tag: autoplay: true, loop: true, muted: true, controls: false, image_size: '1000x' }}
            {%- elsif image != blank -%}
              {{ image | image_url: width: 1400 | image_tag: loading: 'lazy', widths: '450, 700, 900, 1200, 1400', sizes: '(min-width: 990px) 33vw, 100vw', alt: block.settings.image_alt }}
            {%- else -%}
              {{ 'collection-apparel-2' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </a>
          <div class="cz-featured-apparel__body">
            {%- if block.settings.kicker != blank -%}<p class="cz-section-kicker">{{ block.settings.kicker | escape }}</p>{%- endif -%}
            {%- if title != blank -%}<h3>{{ title | escape }}</h3>{%- endif -%}
            {%- if description != blank -%}<div class="rte">{{ description }}</div>{%- endif -%}
            {%- if block.settings.button_label != blank -%}
              <a class="cz-featured-apparel__link" {% if link == blank %}role="link" aria-disabled="true"{% else %}href="{{ link }}"{% endif %}>{{ block.settings.button_label | escape }}</a>
            {%- endif -%}
          </div>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .cz-featured-apparel__header { display: flex; align-items: end; justify-content: space-between; gap: 2.4rem; margin-bottom: clamp(3rem, 5vw, 5rem); }
  .cz-featured-apparel__grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 1.6rem; }
  .cz-featured-apparel__media { aspect-ratio: 4 / 5; border-bottom: 1px solid rgba(17, 17, 17, 0.18); }
  .cz-featured-apparel__body { padding: clamp(2rem, 3vw, 3rem); }
  .cz-featured-apparel__body h3 { margin: 0; color: currentColor; font-size: clamp(2.8rem, 4vw, 4.8rem); line-height: 1; letter-spacing: 0; }
  .cz-featured-apparel__body .rte { margin-top: 1.4rem; color: var(--cz-section-muted); line-height: 1.5; }
  .cz-featured-apparel__link { display: inline-block; margin-top: 2.2rem; color: currentColor; font-weight: 700; text-decoration: underline; text-underline-offset: 0.3rem; }
  @media screen and (max-width: 989px) {
    .cz-featured-apparel__header { align-items: start; flex-direction: column; }
    .cz-featured-apparel__grid { grid-template-columns: 1fr; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "CZ featured apparel",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Apparel" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Featured Apparel" },
    { "type": "richtext", "id": "text", "label": "Body text", "default": "<p>Premium Creative Zoo pieces across classics, golf, and story-led collections.</p>" },
    { "type": "text", "id": "button_label", "label": "CTA text", "default": "View All Apparel" },
    { "type": "url", "id": "button_link", "label": "CTA link" },
    { "type": "select", "id": "mode", "label": "Mode", "options": [{ "value": "light", "label": "Light" }, { "value": "dark", "label": "Dark" }], "default": "light" },
    { "type": "color", "id": "background_color", "label": "Background" },
    { "type": "color", "id": "text_color", "label": "Text" },
    { "type": "color", "id": "card_color", "label": "Card background" },
    { "type": "color", "id": "accent_color", "label": "Accent" },
    { "type": "color", "id": "button_color", "label": "Button" },
    { "type": "color", "id": "button_text_color", "label": "Button text" },
    { "type": "checkbox", "id": "texture_enabled", "label": "Texture overlay", "default": false },
    { "type": "select", "id": "texture_style", "label": "Texture style", "options": [{ "value": "paper", "label": "Paper grain" }, { "value": "fabric", "label": "Fabric" }, { "value": "sketch", "label": "Sketch" }], "default": "fabric" },
    { "type": "range", "id": "texture_opacity", "min": 0, "max": 10, "step": 1, "unit": "%", "label": "Texture opacity", "default": 3 },
    { "type": "range", "id": "padding_top", "min": 0, "max": 140, "step": 4, "unit": "px", "label": "Top padding", "default": 88 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 140, "step": 4, "unit": "px", "label": "Bottom padding", "default": 88 }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection card",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Collection" },
        { "type": "text", "id": "kicker", "label": "Kicker", "default": "Collection" },
        { "type": "text", "id": "fallback_title", "label": "Fallback title", "default": "Collection title" },
        { "type": "richtext", "id": "fallback_text", "label": "Fallback description", "default": "<p>Add collection description.</p>" },
        { "type": "url", "id": "fallback_link", "label": "Fallback link" },
        { "type": "image_picker", "id": "image", "label": "Override image" },
        { "type": "text", "id": "image_alt", "label": "Image alt text" },
        { "type": "video", "id": "video", "label": "Video override" },
        { "type": "text", "id": "button_label", "label": "Button text", "default": "Shop now" }
      ]
    }
  ],
  "presets": [{ "name": "CZ featured apparel" }]
}
{% endschema %}
