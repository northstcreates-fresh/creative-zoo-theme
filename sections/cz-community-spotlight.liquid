{%- liquid
  assign show_embed = false
  assign show_cards = false

  if section.settings.display_mode == 'embed' or section.settings.display_mode == 'both'
    assign show_embed = true
  endif

  if section.settings.display_mode == 'manual' or section.settings.display_mode == 'both'
    assign show_cards = true
  endif

  assign has_embed = false
  if section.settings.instagram_embed != blank
    assign has_embed = true
  endif

  assign has_cards = false
  if section.blocks.size > 0
    assign has_cards = true
  endif
-%}

{%- style -%}
  .section-{{ section.id }} {
    --cz-section-bg: {{ section.settings.background_color | default: settings.cz_primary_background }};
    --cz-section-text: {{ section.settings.text_color | default: settings.cz_primary_text }};
    --cz-section-card: {{ section.settings.card_color | default: settings.cz_card_background }};
    --cz-section-accent: {{ section.settings.accent_color | default: settings.cz_accent_color }};
    --cz-section-button: {{ section.settings.button_color | default: settings.cz_button_color }};
    --cz-section-button-text: {{ section.settings.button_text_color | default: settings.cz_button_text_color }};
    padding-block: {{ section.settings.padding_top | times: 0.75 | round }}px {{ section.settings.padding_bottom | times: 0.75 | round }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} {
      padding-block: {{ section.settings.padding_top }}px {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="cz-community-spotlight cz-surface cz-surface--light section-{{ section.id }}">
  <div class="page-width">
    <div class="cz-community-spotlight__header">
      <div>
        {%- if section.settings.heading != blank -%}
          <h2 class="cz-section-heading">{{ section.settings.heading | escape }}</h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <div class="cz-section-copy rte">{{ section.settings.subheading }}</div>
        {%- endif -%}
      </div>

      <div class="cz-community-spotlight__meta" aria-label="Instagram community tags">
        {%- if section.settings.instagram_handle != blank -%}
          <span>{{ section.settings.instagram_handle | escape }}</span>
        {%- endif -%}
        {%- if section.settings.hashtag != blank -%}
          <span>{{ section.settings.hashtag | escape }}</span>
        {%- endif -%}
      </div>
    </div>

    {%- if show_embed and has_embed -%}
      <div class="cz-community-spotlight__embed">
        {{ section.settings.instagram_embed }}
      </div>
    {%- endif -%}

    {%- if show_cards and has_cards -%}
      <div class="cz-community-spotlight__grid">
        {%- for block in section.blocks -%}
          <article class="cz-community-spotlight__card cz-visual-card" {{ block.shopify_attributes }}>
            <a class="cz-community-spotlight__media cz-visual-media" {% if block.settings.link == blank %}role="link" aria-disabled="true"{% else %}href="{{ block.settings.link }}" target="_blank" rel="noopener noreferrer"{% endif %}>
              {%- if block.settings.image != blank -%}
                {{
                  block.settings.image
                  | image_url: width: 1000
                  | image_tag:
                    loading: 'lazy',
                    widths: '360, 550, 750, 1000',
                    sizes: '(min-width: 990px) 25vw, (min-width: 750px) 50vw, 100vw',
                    alt: block.settings.image_alt
                }}
              {%- else -%}
                {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
            </a>
            <div class="cz-community-spotlight__body">
              {%- if block.settings.name != blank -%}
                <h3>{{ block.settings.name | escape }}</h3>
              {%- endif -%}
              {%- if block.settings.handle != blank -%}
                <p class="cz-community-spotlight__handle">{{ block.settings.handle | escape }}</p>
              {%- endif -%}
              {%- if block.settings.caption != blank -%}
                <div class="cz-community-spotlight__caption rte">{{ block.settings.caption }}</div>
              {%- endif -%}
              {%- if block.settings.link != blank -%}
                <a class="cz-community-spotlight__link" href="{{ block.settings.link }}" target="_blank" rel="noopener noreferrer">
                  {{ block.settings.link_label | escape }}
                </a>
              {%- endif -%}
            </div>
          </article>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- unless has_embed or has_cards -%}
      <div class="cz-community-spotlight__fallback">
        {{ section.settings.fallback_text | escape }}
      </div>
    {%- endunless -%}

    {%- if section.settings.cta_text != blank -%}
      <div class="cz-community-spotlight__cta">
        <a class="cz-visual-button" {% if section.settings.cta_link == blank %}role="link" aria-disabled="true"{% else %}href="{{ section.settings.cta_link }}"{% endif %}>
          {{ section.settings.cta_text | escape }}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .cz-community-spotlight {
    color: var(--cz-section-text, var(--cz-black));
    background:
      linear-gradient(180deg, rgba(216, 214, 208, 0.24), rgba(248, 247, 244, 0) 42%),
      var(--cz-section-bg, var(--cz-canvas));
  }

  .cz-community-spotlight__header {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 2.4rem;
    align-items: end;
    margin-bottom: clamp(3rem, 5vw, 5.6rem);
  }

  .cz-community-spotlight__meta {
    display: flex;
    flex-wrap: wrap;
    justify-content: end;
    gap: 0.8rem;
    max-width: 36rem;
  }

  .cz-community-spotlight__meta span {
    display: inline-flex;
    align-items: center;
    min-height: 3.6rem;
    border: 1px solid color-mix(in srgb, var(--cz-section-text, var(--cz-black)) 26%, transparent);
    border-radius: 8px;
    padding: 0.7rem 1.2rem;
    color: var(--cz-section-text, var(--cz-black));
    background: color-mix(in srgb, var(--cz-section-card, #ffffff) 84%, transparent);
    font-weight: 700;
  }

  .cz-community-spotlight__embed {
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--cz-section-text, var(--cz-black)) 18%, transparent);
    border-radius: 8px;
    margin-bottom: 2.4rem;
    background: var(--cz-section-card, #ffffff);
    padding: clamp(1.2rem, 3vw, 2.4rem);
  }

  .cz-community-spotlight__embed iframe,
  .cz-community-spotlight__embed blockquote,
  .cz-community-spotlight__embed div {
    max-width: 100%;
  }

  .cz-community-spotlight__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1.6rem;
  }

  .cz-community-spotlight__card {
    transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;
  }

  .cz-community-spotlight__card:hover {
    transform: translateY(-0.4rem);
    border-color: color-mix(in srgb, var(--cz-section-accent, var(--cz-gold)) 72%, var(--cz-section-text, var(--cz-black)));
    box-shadow: 0 1.6rem 3.2rem rgba(17, 17, 17, 0.1);
  }

  .cz-community-spotlight__media {
    aspect-ratio: 1 / 1;
    border-bottom: 1px solid color-mix(in srgb, var(--cz-section-text, var(--cz-black)) 18%, transparent);
  }

  .cz-community-spotlight__body {
    padding: clamp(1.8rem, 2.5vw, 2.4rem);
  }

  .cz-community-spotlight__body h3 {
    margin: 0;
    color: currentColor;
    font-size: clamp(2rem, 2.4vw, 2.8rem);
    line-height: 1.05;
    letter-spacing: 0;
  }

  .cz-community-spotlight__handle {
    margin: 0.8rem 0 0;
    color: var(--cz-section-accent, var(--cz-gold));
    font-weight: 700;
  }

  .cz-community-spotlight__caption {
    margin-top: 1.4rem;
    color: var(--cz-section-muted, rgba(17, 17, 17, 0.68));
    line-height: 1.5;
  }

  .cz-community-spotlight__link {
    display: inline-block;
    margin-top: 1.8rem;
    color: currentColor;
    font-weight: 700;
    text-decoration: underline;
    text-underline-offset: 0.3rem;
  }

  .cz-community-spotlight__fallback {
    border: 1px solid color-mix(in srgb, var(--cz-section-text, var(--cz-black)) 18%, transparent);
    border-radius: 8px;
    background: var(--cz-section-card, #ffffff);
    padding: clamp(2rem, 4vw, 4rem);
    color: var(--cz-section-muted, rgba(17, 17, 17, 0.68));
    font-size: clamp(1.8rem, 2vw, 2.4rem);
    line-height: 1.45;
  }

  .cz-community-spotlight__cta {
    margin-top: 3rem;
  }

  @media screen and (max-width: 1199px) {
    .cz-community-spotlight__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media screen and (max-width: 749px) {
    .cz-community-spotlight__header {
      grid-template-columns: 1fr;
      align-items: start;
    }

    .cz-community-spotlight__meta {
      justify-content: start;
    }

    .cz-community-spotlight__grid {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "CZ community spotlight",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Community Spotlights" },
    { "type": "richtext", "id": "subheading", "label": "Subheading", "default": "<p>See how the Habitat shows up in the wild. Tag @creativzoo or use #CreativeZooHabitat for a chance to be featured.</p>" },
    { "type": "text", "id": "instagram_handle", "label": "Instagram handle", "default": "@creativzoo" },
    { "type": "text", "id": "hashtag", "label": "Hashtag", "default": "#CreativeZooHabitat" },
    {
      "type": "select",
      "id": "display_mode",
      "label": "Content display",
      "options": [
        { "value": "embed", "label": "Show Instagram embed" },
        { "value": "manual", "label": "Show manual spotlight cards" },
        { "value": "both", "label": "Show both" }
      ],
      "default": "manual"
    },
    { "type": "liquid", "id": "instagram_embed", "label": "Instagram feed app embed code" },
    { "type": "text", "id": "cta_text", "label": "CTA text", "default": "Follow @creativzoo" },
    { "type": "url", "id": "cta_link", "label": "CTA link", "default": "https://www.instagram.com/creativzoo/" },
    { "type": "text", "id": "fallback_text", "label": "Fallback text", "default": "Tag @creativezoo or use #CreativeZooHabitat to be featured in the Habitat." },
    { "type": "color", "id": "background_color", "label": "Background" },
    { "type": "color", "id": "text_color", "label": "Text" },
    { "type": "color", "id": "card_color", "label": "Card background" },
    { "type": "color", "id": "accent_color", "label": "Accent" },
    { "type": "color", "id": "button_color", "label": "Button" },
    { "type": "color", "id": "button_text_color", "label": "Button text" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 140, "step": 4, "unit": "px", "label": "Top padding", "default": 88 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 140, "step": 4, "unit": "px", "label": "Bottom padding", "default": 88 }
  ],
  "blocks": [
    {
      "type": "spotlight",
      "name": "Manual spotlight",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "image_alt", "label": "Image alt text" },
        { "type": "text", "id": "name", "label": "Name", "default": "Community Member" },
        { "type": "text", "id": "handle", "label": "Instagram handle", "default": "@creativezoo" },
        { "type": "richtext", "id": "caption", "label": "Short quote or caption", "default": "<p>Showcasing a Creative Zoo community moment from the Habitat.</p>" },
        { "type": "url", "id": "link", "label": "Instagram post or profile link" },
        { "type": "text", "id": "link_label", "label": "Link text", "default": "View on Instagram" }
      ]
    }
  ],
  "presets": [
    {
      "name": "CZ community spotlight",
      "blocks": [
        { "type": "spotlight" },
        { "type": "spotlight" },
        { "type": "spotlight" }
      ]
    }
  ]
}
{% endschema %}
