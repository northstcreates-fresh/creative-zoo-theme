{%- style -%}
  .section-{{ section.id }} {
    --cz-grid-bg: {{ section.settings.background_color }};
    --cz-grid-card: {{ section.settings.card_color }};
    --cz-grid-text: {{ section.settings.text_color }};
    --cz-grid-muted: {{ section.settings.muted_color }};
    --cz-grid-accent: {{ section.settings.accent_color }};
    --cz-grid-border: {{ section.settings.border_color }};
    --cz-grid-padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    --cz-grid-padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} {
      --cz-grid-padding-top: {{ section.settings.padding_top }}px;
      --cz-grid-padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="cz-habitat-grid section-{{ section.id }}">
  <div class="page-width">
    <div class="cz-habitat-grid__header">
      {%- if section.settings.eyebrow != blank -%}
        <p>{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2>{{ section.settings.heading | escape }}</h2>
      {%- endif -%}

      {%- if section.settings.text != blank -%}
        <div class="rte">{{ section.settings.text }}</div>
      {%- endif -%}
    </div>

    <div class="cz-habitat-grid__cards">
      {%- for block in section.blocks -%}
        {%- if block.type == 'card' -%}
          <article class="cz-habitat-grid__card" {{ block.shopify_attributes }}>
            <a
              class="cz-habitat-grid__card-link"
              {% if block.settings.link == blank %}
                role="link" aria-disabled="true"
              {% else %}
                href="{{ block.settings.link }}"
              {% endif %}
            >
              <span class="cz-habitat-grid__media">
                {%- if block.settings.image != blank -%}
                  {{
                    block.settings.image
                    | image_url: width: 900
                    | image_tag:
                      loading: 'lazy',
                      widths: '320, 550, 750, 900',
                      sizes: '(min-width: 990px) 20vw, (min-width: 750px) 33vw, 100vw',
                      class: 'cz-habitat-grid__image'
                  }}
                {%- else -%}
                  {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg cz-habitat-grid__placeholder' }}
                {%- endif -%}
              </span>

              <span class="cz-habitat-grid__content">
                <span class="cz-habitat-grid__kicker">{{ block.settings.kicker | escape }}</span>
                <span class="cz-habitat-grid__title">{{ block.settings.title | escape }}</span>
                <span class="cz-habitat-grid__text">{{ block.settings.text | strip_html | escape }}</span>
                <span class="cz-habitat-grid__cta">
                  {{ block.settings.link_label | escape }}
                  <span aria-hidden="true">{{ 'icon-arrow.svg' | inline_asset_content }}</span>
                </span>
              </span>
            </a>
          </article>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .cz-habitat-grid {
    color: var(--cz-grid-text);
    background: var(--cz-grid-bg);
    padding-block: var(--cz-grid-padding-top) var(--cz-grid-padding-bottom);
  }

  .cz-habitat-grid__header {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 1.8rem;
    margin-bottom: clamp(3rem, 5vw, 5rem);
  }

  .cz-habitat-grid__header p {
    margin: 0;
    color: var(--cz-grid-accent);
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .cz-habitat-grid__header h2 {
    margin: 0;
    color: currentColor;
    font-family: var(--font-heading-family);
    font-size: clamp(3.8rem, 6vw, 7rem);
    line-height: 0.95;
    letter-spacing: 0;
  }

  .cz-habitat-grid__header .rte {
    max-width: 68rem;
    color: var(--cz-grid-muted);
    font-size: 1.8rem;
    line-height: 1.5;
  }

  .cz-habitat-grid__cards {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 1.2rem;
  }

  .cz-habitat-grid__card {
    min-width: 0;
  }

  .cz-habitat-grid__card-link {
    display: grid;
    height: 100%;
    overflow: hidden;
    border: 1px solid var(--cz-grid-border);
    border-radius: 8px;
    background: var(--cz-grid-card);
    color: currentColor;
    text-decoration: none;
  }

  .cz-habitat-grid__media {
    display: block;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border-bottom: 1px solid var(--cz-grid-border);
    background: #ffffff;
  }

  .cz-habitat-grid__image,
  .cz-habitat-grid__placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 180ms ease;
  }

  .cz-habitat-grid__card-link:hover .cz-habitat-grid__image {
    transform: scale(1.04);
  }

  .cz-habitat-grid__content {
    display: grid;
    gap: 1rem;
    padding: 1.8rem;
  }

  .cz-habitat-grid__kicker {
    color: var(--cz-grid-accent);
    font-size: 1.1rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .cz-habitat-grid__title {
    font-family: var(--font-heading-family);
    font-size: clamp(2.2rem, 3vw, 3rem);
    font-weight: 700;
    line-height: 1;
  }

  .cz-habitat-grid__text {
    color: var(--cz-grid-muted);
    font-size: 1.4rem;
    line-height: 1.4;
  }

  .cz-habitat-grid__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    padding-top: 1rem;
    font-weight: 700;
  }

  .cz-habitat-grid__cta span {
    display: inline-flex;
    width: 1.4rem;
  }

  @media screen and (max-width: 1199px) {
    .cz-habitat-grid__cards {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media screen and (max-width: 749px) {
    .cz-habitat-grid__cards {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "CZ habitat grid",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Explore the Habitat"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Five ways into the Zoo."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Move through apparel, manga, music, journal entries, and community moments from one connected home base.</p>"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#f4f4f4"
    },
    {
      "type": "color",
      "id": "card_color",
      "label": "Card background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "muted_color",
      "label": "Muted text",
      "default": "#4a4a4a"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent",
      "default": "#f50b0b"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border",
      "default": "#121212"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 140,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 140,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 80
