          "id": "kicker",
          "label": "Kicker",
          "default": "Zone"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Apparel"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Wearable pieces from the Creative Zoo world."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Link label",
          "default": "Explore"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "CZ habitat grid",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "title": "Apparel"
          }
        },
        {
          "type": "card",
          "settings": {
            "title": "Manga"
          }
        },
        {
          "type": "card",
          "settings": {
            "title": "Music"
          }
        },
        {
          "type": "card",
          "settings": {
            "title": "Journal"
          }
        },
        {
          "type": "card",
