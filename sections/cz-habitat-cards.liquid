{%- liquid
  assign mode_class = 'cz-surface--light'
  if section.settings.mode == 'dark'
    assign mode_class = 'cz-surface--dark'
  endif
  assign texture_class = ''
  if section.settings.texture_enabled
    assign texture_class = 'cz-texture cz-texture--' | append: section.settings.texture_style
  endif
-%}

{%- style -%}
  .section-{{ section.id }} {
    --cz-section-bg: {{ section.settings.background_color | default: settings.cz_primary_background }};
    --cz-section-text: {{ section.settings.text_color | default: settings.cz_primary_text }};
    --cz-section-card: {{ section.settings.card_color | default: settings.cz_card_background }};
    --cz-section-accent: {{ section.settings.accent_color | default: settings.cz_accent_color }};
    --cz-section-button: {{ section.settings.button_color | default: settings.cz_button_color }};
    --cz-section-button-text: {{ section.settings.button_text_color | default: settings.cz_button_text_color }};
    --cz-texture-opacity: {{ section.settings.texture_opacity | divided_by: 100.0 }};
    --cz-grid-columns: {{ section.settings.columns_desktop }};
    --cz-card-media-fit: {{ section.settings.media_fit }};
    --cz-card-media-position: {{ section.settings.media_position }};
    padding-block: {{ section.settings.padding_top | times: 0.75 | round }}px {{ section.settings.padding_bottom | times: 0.75 | round }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }} { padding-block: {{ section.settings.padding_top }}px {{ section.settings.padding_bottom }}px; }
  }
{%- endstyle -%}

<section class="cz-habitat-cards cz-surface {{ mode_class }} {{ texture_class }} section-{{ section.id }}">
  <div class="page-width">
    <div class="cz-habitat-cards__header">
      {%- if section.settings.eyebrow != blank -%}<p class="cz-section-kicker">{{ section.settings.eyebrow | escape }}</p>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h2 class="cz-section-heading">{{ section.settings.heading | escape }}</h2>{%- endif -%}
      {%- if section.settings.text != blank -%}<div class="cz-section-copy rte">{{ section.settings.text }}</div>{%- endif -%}
    </div>
    <div class="cz-habitat-cards__grid">
      {%- for block in section.blocks -%}
        <article class="cz-visual-card cz-habitat-cards__card" {{ block.shopify_attributes }}>
          <div class="cz-visual-media cz-habitat-cards__media">
            {%- if block.settings.video != blank -%}
              {{ block.settings.video | video_tag: autoplay: section.settings.video_autoplay, loop: section.settings.video_loop, muted: section.settings.video_muted, playsinline: true, controls: false, image_size: '1000x' }}
            {%- elsif block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', widths: '450, 700, 900, 1200', sizes: '(min-width: 990px) 25vw, 100vw', alt: block.settings.image_alt }}
            {%- else -%}
              {{ 'collection-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </div>
          <div class="cz-habitat-cards__body">
            {%- if block.settings.kicker != blank -%}<p class="cz-section-kicker">{{ block.settings.kicker | escape }}</p>{%- endif -%}
            {%- if block.settings.title != blank -%}<h3>{{ block.settings.title | escape }}</h3>{%- endif -%}
            {%- if block.settings.text != blank -%}<div class="rte">{{ block.settings.text }}</div>{%- endif -%}
            {%- if block.settings.button_label != blank -%}
              <a class="cz-habitat-cards__link" {% if block.settings.button_link == blank %}role="link" aria-disabled="true"{% else %}href="{{ block.settings.button_link }}"{% endif %}>{{ block.settings.button_label | escape }}</a>
            {%- endif -%}
          </div>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .cz-habitat-cards__header { margin-bottom: clamp(3rem, 5vw, 5rem); }
  .cz-habitat-cards__grid { display: grid; grid-template-columns: repeat(var(--cz-grid-columns), minmax(0, 1fr)); gap: 1.6rem; }
  .cz-habitat-cards__card { display: flex; flex-direction: column; }
  .cz-habitat-cards__media { aspect-ratio: 4 / 3; border-bottom: 1px solid rgba(17, 17, 17, 0.22); }
  .cz-habitat-cards__media img,
  .cz-habitat-cards__media video,
  .cz-habitat-cards__media svg { object-fit: var(--cz-card-media-fit, cover); object-position: var(--cz-card-media-position, center center); }
  .cz-habitat-cards__body { display: flex; flex: 1; flex-direction: column; min-height: 24rem; padding: clamp(2rem, 3vw, 3.2rem); }
  .cz-habitat-cards__body h3 { margin: 0; color: currentColor; font-family: var(--font-heading-family); font-size: clamp(3rem, 4vw, 5rem); line-height: 0.98; letter-spacing: 0; }
  .cz-habitat-cards__body .rte { margin-top: 1.5rem; color: var(--cz-section-muted); line-height: 1.5; }
  .cz-habitat-cards__link { margin-top: auto; padding-top: 2.4rem; color: currentColor; font-weight: 700; text-decoration: underline; text-underline-offset: 0.3rem; }
  @media screen and (max-width: 989px) { .cz-habitat-cards__grid { grid-template-columns: 1fr; } }
{% endstylesheet %}

{% schema %}
{
  "name": "CZ habitat cards",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Explore" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "The Habitat" },
    { "type": "richtext", "id": "text", "label": "Body text" },
    { "type": "select", "id": "mode", "label": "Mode", "options": [{ "value": "light", "label": "Light" }, { "value": "dark", "label": "Dark" }], "default": "light" },
    { "type": "color", "id": "background_color", "label": "Background" },
    { "type": "color", "id": "text_color", "label": "Text" },
    { "type": "color", "id": "card_color", "label": "Card background" },
    { "type": "color", "id": "accent_color", "label": "Accent" },
    { "type": "color", "id": "button_color", "label": "Button" },
    { "type": "color", "id": "button_text_color", "label": "Button text" },
    { "type": "select", "id": "media_fit", "label": "Card media fit", "options": [{ "value": "cover", "label": "Cover" }, { "value": "contain", "label": "Contain" }, { "value": "fill", "label": "Fill" }], "default": "cover" },
    { "type": "select", "id": "media_position", "label": "Card media focal point", "options": [{ "value": "center center", "label": "Center center" }, { "value": "top center", "label": "Top center" }, { "value": "bottom center", "label": "Bottom center" }, { "value": "left center", "label": "Left center" }, { "value": "right center", "label": "Right center" }], "default": "center center" },
    { "type": "checkbox", "id": "video_autoplay", "label": "Autoplay card videos", "default": true },
    { "type": "checkbox", "id": "video_muted", "label": "Mute card videos by default", "default": true },
    { "type": "checkbox", "id": "video_loop", "label": "Loop card videos", "default": true },
    { "type": "checkbox", "id": "texture_enabled", "label": "Texture overlay", "default": false },
    { "type": "select", "id": "texture_style", "label": "Texture style", "options": [{ "value": "paper", "label": "Paper grain" }, { "value": "fabric", "label": "Fabric" }, { "value": "sketch", "label": "Sketch" }], "default": "paper" },
    { "type": "range", "id": "texture_opacity", "min": 0, "max": 10, "step": 1, "unit": "%", "label": "Texture opacity", "default": 4 },
    { "type": "range", "id": "columns_desktop", "min": 2, "max": 4, "step": 1, "label": "Desktop columns", "default": 4 },
    { "type": "range", "id": "padding_top", "min": 0, "max": 140, "step": 4, "unit": "px", "label": "Top padding", "default": 72 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 140, "step": 4, "unit": "px", "label": "Bottom padding", "default": 72 }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        { "type": "text", "id": "kicker", "label": "Kicker" },
        { "type": "text", "id": "title", "label": "Title", "default": "Card title" },
        { "type": "richtext", "id": "text", "label": "Description", "default": "<p>Add card description.</p>" },
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "image_alt", "label": "Image alt text" },
        { "type": "video", "id": "video", "label": "Video" },
        { "type": "text", "id": "button_label", "label": "Button text", "default": "Explore" },
        { "type": "url", "id": "button_link", "label": "Button link" }
      ]
    }
  ],
  "presets": [{ "name": "CZ habitat cards" }]
}
{% endschema %}
