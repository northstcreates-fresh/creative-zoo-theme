        {
          "type": "richtext",
          "id": "fallback_text",
          "label": "Fallback description",
          "default": "<p>Select a collection to pull its title, image, and description.</p>"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "View Collection"
        },
        {
          "type": "url",
          "id": "fallback_link",
          "label": "Fallback link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "CZ collection cards",
      "blocks": [
        {
          "type": "collection_card"
        },
        {
          "type": "collection_card"
        },
        {
          "type": "collection_card"
        }
      ]
    }
  ]
