{%- style -%}
  .section-{{ section.id }} {
    --cz-collections-bg: {{ section.settings.background_color }};
    --cz-collections-card: {{ section.settings.card_color }};
    --cz-collections-text: {{ section.settings.text_color }};
    --cz-collections-muted: {{ section.settings.muted_color }};
    --cz-collections-accent: {{ section.settings.accent_color }};
    --cz-collections-border: {{ section.settings.border_color }};
    --cz-collections-padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    --cz-collections-padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} {
      --cz-collections-padding-top: {{ section.settings.padding_top }}px;
      --cz-collections-padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="cz-collection-cards section-{{ section.id }}">
  <div class="page-width">
    <div class="cz-collection-cards__header">
      {%- if section.settings.eyebrow != blank -%}
        <p>{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2>{{ section.settings.heading | escape }}</h2>
      {%- endif -%}

      {%- if section.settings.text != blank -%}
        <div class="rte">{{ section.settings.text }}</div>
      {%- endif -%}
    </div>

    <div class="cz-collection-cards__grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'collection_card' -%}
          {%- liquid
            assign featured_collection = block.settings.collection
            assign card_image = blank

            if featured_collection.image != blank
              assign card_image = featured_collection.image
            elsif featured_collection.featured_image != blank
              assign card_image = featured_collection.featured_image
            elsif featured_collection.products.first.featured_image != blank
              assign card_image = featured_collection.products.first.featured_image
            endif
          -%}

          <article class="cz-collection-cards__card" {{ block.shopify_attributes }}>
            <div class="cz-collection-cards__media">
              {%- if card_image != blank -%}
                {{
                  card_image
                  | image_url: width: 1400
                  | image_tag:
                    loading: 'lazy',
                    widths: '550, 750, 990, 1200, 1400',
                    sizes: '(min-width: 990px) 33vw, 100vw',
                    class: 'cz-collection-cards__image'
                }}
              {%- else -%}
                {{ 'collection-apparel-1' | placeholder_svg_tag: 'placeholder-svg cz-collection-cards__placeholder' }}
              {%- endif -%}
            </div>

            <div class="cz-collection-cards__body">
              {%- if featured_collection != blank -%}
                <h3>{{ featured_collection.title | escape }}</h3>

                {%- if featured_collection.description != blank -%}
                  <div class="rte">{{ featured_collection.description }}</div>
                {%- endif -%}
              {%- else -%}
                <h3>{{ block.settings.fallback_title | escape }}</h3>

                {%- if block.settings.fallback_text != blank -%}
                  <div class="rte">{{ block.settings.fallback_text }}</div>
                {%- endif -%}
              {%- endif -%}

              {%- if block.settings.button_label != blank -%}
                <a
                  class="cz-collection-cards__link"
                  {% if featured_collection != blank %}
                    href="{{ featured_collection.url }}"
                  {% elsif block.settings.fallback_link != blank %}
                    href="{{ block.settings.fallback_link }}"
                  {% else %}
                    role="link" aria-disabled="true"
                  {% endif %}
                >
                  {{ block.settings.button_label | escape }}
                  <span aria-hidden="true">{{ 'icon-arrow.svg' | inline_asset_content }}</span>
                </a>
              {%- endif -%}
            </div>
          </article>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- if section.settings.button_label != blank -%}
      <div class="cz-collection-cards__cta">
        <a
          class="button button--primary"
          {% if section.settings.button_link == blank %}
            role="link" aria-disabled="true"
          {% else %}
            href="{{ section.settings.button_link }}"
          {% endif %}
        >
          {{ section.settings.button_label | escape }}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .cz-collection-cards {
    color: var(--cz-collections-text);
    background: var(--cz-collections-bg);
    padding-block: var(--cz-collections-padding-top) var(--cz-collections-padding-bottom);
  }

  .cz-collection-cards__header {
    display: grid;
    gap: 1.6rem;
    margin-bottom: clamp(3rem, 5vw, 5rem);
  }

  .cz-collection-cards__header p {
    margin: 0;
    color: var(--cz-collections-accent);
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .cz-collection-cards__header h2 {
    margin: 0;
    color: currentColor;
    font-family: var(--font-heading-family);
    font-size: clamp(3.8rem, 6vw, 7.6rem);
    line-height: 0.95;
    letter-spacing: 0;
  }

  .cz-collection-cards__header .rte {
    max-width: 72rem;
    color: var(--cz-collections-muted);
    font-size: 1.8rem;
    line-height: 1.5;
  }

  .cz-collection-cards__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.6rem;
  }

  .cz-collection-cards__card {
    display: flex;
    min-height: 100%;
    flex-direction: column;
    overflow: hidden;
    border: 1px solid var(--cz-collections-border);
    border-radius: 8px;
    background: var(--cz-collections-card);
  }

  .cz-collection-cards__media {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border-bottom: 1px solid var(--cz-collections-border);
    background: #ffffff;
  }

  .cz-collection-cards__image,
  .cz-collection-cards__placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .cz-collection-cards__body {
    display: flex;
    min-height: 24rem;
    flex: 1;
    flex-direction: column;
    padding: clamp(2rem, 3vw, 3.2rem);
  }

  .cz-collection-cards__body h3 {
    margin: 0;
    color: currentColor;
    font-family: var(--font-heading-family);
    font-size: clamp(2.8rem, 4vw, 4.8rem);
    line-height: 0.98;
    letter-spacing: 0;
  }

  .cz-collection-cards__body .rte {
    margin-top: 1.6rem;
    color: var(--cz-collections-muted);
    line-height: 1.5;
  }

  .cz-collection-cards__link {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    margin-top: auto;
    padding-top: 2.4rem;
    color: currentColor;
    font-weight: 700;
    text-decoration: none;
  }

  .cz-collection-cards__link span {
    display: inline-flex;
    width: 1.4rem;
  }

  .cz-collection-cards__cta {
    margin-top: clamp(3rem, 5vw, 5rem);
    text-align: center;
  }

  @media screen and (max-width: 989px) {
    .cz-collection-cards__grid {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

{% schema %}
