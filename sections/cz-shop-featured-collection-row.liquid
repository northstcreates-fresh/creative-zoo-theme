{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}

{%- unless section.settings.quick_add == 'none' -%}
  {{ 'quick-add.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
{%- endunless -%}

{%- if section.settings.quick_add == 'standard' -%}
  <script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- if section.settings.quick_add == 'bulk' -%}
  <script src="{{ 'quick-add-bulk.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'quantity-popover.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'price-per-item.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'quick-order-list.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- liquid
  assign mode_class = 'cz-surface--light'
  if section.settings.mode == 'dark'
    assign mode_class = 'cz-surface--dark'
  endif
  assign texture_class = ''
  if section.settings.texture_enabled
    assign texture_class = 'cz-texture cz-texture--' | append: section.settings.texture_style
  endif
  assign cta_link = section.settings.button_link
  if cta_link == blank and section.settings.collection != blank
    assign cta_link = section.settings.collection.url
  endif
-%}

{%- style -%}
  .section-{{ section.id }} {
    --cz-section-bg: {{ section.settings.background_color | default: settings.cz_primary_background }};
    --cz-section-text: {{ section.settings.text_color | default: settings.cz_primary_text }};
    --cz-section-accent: {{ section.settings.accent_color | default: settings.cz_accent_color }};
    --cz-section-button: {{ section.settings.button_color | default: settings.cz_button_color }};
    --cz-section-button-text: {{ section.settings.button_text_color | default: settings.cz_button_text_color }};
    --cz-texture-opacity: {{ section.settings.texture_opacity | divided_by: 100.0 }};
    padding-block: {{ section.settings.padding_top | times: 0.75 | round }}px {{ section.settings.padding_bottom | times: 0.75 | round }}px;
  }
  @media screen and (min-width: 750px) { .section-{{ section.id }} { padding-block: {{ section.settings.padding_top }}px {{ section.settings.padding_bottom }}px; } }
{%- endstyle -%}

<section class="cz-shop-collection-row cz-surface {{ mode_class }} {{ texture_class }} section-{{ section.id }}">
  <div class="page-width">
    <div class="cz-shop-collection-row__header">
      <div class="cz-shop-collection-row__copy">
        {%- if section.settings.eyebrow != blank -%}<p class="cz-section-kicker">{{ section.settings.eyebrow | escape }}</p>{%- endif -%}
        {%- if section.settings.heading != blank -%}<h2 class="cz-section-heading">{{ section.settings.heading | escape }}</h2>{%- endif -%}
        {%- if section.settings.text != blank -%}<div class="cz-section-copy rte">{{ section.settings.text }}</div>{%- endif -%}
      </div>
      {%- if section.settings.button_label != blank -%}
        <a class="cz-visual-button" {% if cta_link == blank %}role="link" aria-disabled="true"{% else %}href="{{ cta_link }}"{% endif %}>{{ section.settings.button_label | escape }}</a>
      {%- endif -%}
    </div>

    <ul class="cz-shop-collection-row__grid grid product-grid contains-card contains-card--product{% if settings.card_style == 'standard' %} contains-card--standard{% endif %}" role="list">
      {%- if section.settings.collection != blank and section.settings.collection.products.size > 0 -%}
        {%- assign skip_card_product_styles = false -%}
        {%- for product in section.settings.collection.products limit: section.settings.products_to_show -%}
          <li class="cz-shop-collection-row__item grid__item">
            {% render 'card-product', card_product: product, media_aspect_ratio: section.settings.image_ratio, image_shape: 'default', lazy_load: true, show_secondary_image: section.settings.show_secondary_image, show_vendor: section.settings.show_vendor, show_rating: section.settings.show_rating, skip_styles: skip_card_product_styles, section_id: section.id, quick_add: section.settings.quick_add %}
          </li>
          {%- assign skip_card_product_styles = true -%}
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..section.settings.products_to_show) -%}
          <li class="cz-shop-collection-row__item grid__item">
            {%- assign placeholder_image = 'product-apparel-' | append: forloop.index -%}
            {% render 'card-product', media_aspect_ratio: section.settings.image_ratio, image_shape: 'default', lazy_load: true, show_vendor: section.settings.show_vendor, placeholder_image: placeholder_image %}
          </li>
        {%- endfor -%}
      {%- endif -%}
    </ul>
  </div>
</section>

{% stylesheet %}
  .cz-shop-collection-row__header { display: grid; grid-template-columns: minmax(0, 1fr) auto; gap: 2.4rem; align-items: end; margin-bottom: clamp(3.2rem, 5vw, 5.6rem); }
  .cz-shop-collection-row__copy { max-width: 84rem; }
  .cz-shop-collection-row .cz-section-heading { font-size: clamp(3.6rem, 5vw, 7rem); }
  .cz-shop-collection-row__grid { display: grid; grid-template-columns: repeat(var(--cz-shop-columns, 4), minmax(0, 1fr)); gap: 1.6rem; margin: 0; padding: 0; }
  .cz-shop-collection-row__item { width: auto; max-width: none; }
  @media screen and (min-width: 990px) { .cz-shop-collection-row__grid { --cz-shop-columns: 4; } }
  @media screen and (max-width: 989px) { .cz-shop-collection-row__header { grid-template-columns: 1fr; align-items: start; } .cz-shop-collection-row__grid { --cz-shop-columns: 2; } }
  @media screen and (max-width: 599px) { .cz-shop-collection-row__grid { --cz-shop-columns: 1; } }
{% endstylesheet %}

{% schema %}
{"name":"CZ shop collection row","settings":[{"type":"text","id":"eyebrow","label":"Eyebrow","default":"Shop"},{"type":"text","id":"heading","label":"Heading","default":"Collection"},{"type":"richtext","id":"text","label":"Body text","default":"<p>Feature a curated product set from a Shopify collection.</p>"},{"type":"collection","id":"collection","label":"Collection"},{"type":"range","id":"products_to_show","min":2,"max":8,"step":1,"label":"Products to show","default":4},{"type":"text","id":"button_label","label":"CTA text","default":"Shop collection"},{"type":"url","id":"button_link","label":"CTA link override"},{"type":"select","id":"image_ratio","label":"Image ratio","options":[{"value":"adapt","label":"Adapt to image"},{"value":"portrait","label":"Portrait"},{"value":"square","label":"Square"}],"default":"portrait"},{"type":"checkbox","id":"show_secondary_image","label":"Show second image on hover","default":true},{"type":"checkbox","id":"show_vendor","label":"Show vendor","default":false},{"type":"checkbox","id":"show_rating","label":"Show product rating","default":false},{"type":"select","id":"quick_add","label":"Quick add","options":[{"value":"none","label":"None"},{"value":"standard","label":"Standard"},{"value":"bulk","label":"Bulk"}],"default":"none"},{"type":"select","id":"mode","label":"Mode","options":[{"value":"light","label":"Light"},{"value":"dark","label":"Dark"}],"default":"light"},{"type":"color","id":"background_color","label":"Background"},{"type":"color","id":"text_color","label":"Text"},{"type":"color","id":"accent_color","label":"Accent"},{"type":"color","id":"button_color","label":"Button"},{"type":"color","id":"button_text_color","label":"Button text"},{"type":"checkbox","id":"texture_enabled","label":"Texture overlay","default":false},{"type":"select","id":"texture_style","label":"Texture style","options":[{"value":"paper","label":"Paper grain"},{"value":"fabric","label":"Fabric"},{"value":"sketch","label":"Sketch"}],"default":"paper"},{"type":"range","id":"texture_opacity","min":0,"max":10,"step":1,"unit":"%","label":"Texture opacity","default":3},{"type":"range","id":"padding_top","min":0,"max":140,"step":4,"unit":"px","label":"Top padding","default":88},{"type":"range","id":"padding_bottom","min":0,"max":140,"step":4,"unit":"px","label":"Bottom padding","default":88}],"presets":[{"name":"CZ shop collection row"}]}
{% endschema %}
