":"Texture overlay","default":false},{"type":"select","id":"texture_style","label":"Texture style","options":[{"value":"paper","label":"Paper grain"},{"value":"fabric","label":"Fabric"},{"value":"sketch","label":"Sketch"}],"default":"paper"},{"type":"range","id":"texture_opacity","min":0,"max":10,"step":1,"unit":"%","label":"Texture opacity","default":3},{"type":"range","id":"padding_top","min":0,"max":160,"step":4,"unit":"px","label":"Top padding","default":96},{"type":"range","id":"padding_bottom","min":0,"max":160,"step":4,"unit":"px","label":"Bottom padding","default":96}],"presets":[{"name":"CZ habitat feature row"}]}
{% endschema %}
