{%- liquid
  assign mode_class = 'cz-surface--light'
  if section.settings.mode == 'dark'
    assign mode_class = 'cz-surface--dark'
  endif
  assign texture_class = ''
  if section.settings.texture_enabled
    assign texture_class = 'cz-texture cz-texture--' | append: section.settings.texture_style
  endif
-%}
{%- style -%}
  .section-{{ section.id }} {
    --cz-section-bg: {{ section.settings.background_color | default: settings.cz_primary_background }};
    --cz-section-text: {{ section.settings.text_color | default: settings.cz_primary_text }};
    --cz-section-accent: {{ section.settings.accent_color | default: settings.cz_accent_color }};
    --cz-section-button: {{ section.settings.button_color | default: settings.cz_button_color }};
    --cz-section-button-text: {{ section.settings.button_text_color | default: settings.cz_button_text_color }};
    --cz-texture-opacity: {{ section.settings.texture_opacity | divided_by: 100.0 }};
    --cz-feature-media-scale: {{ section.settings.media_scale | divided_by: 100.0 }};
    padding-block: {{ section.settings.padding_top | times: 0.75 | round }}px {{ section.settings.padding_bottom | times: 0.75 | round }}px;
  }
  @media screen and (min-width: 750px) { .section-{{ section.id }} { padding-block: {{ section.settings.padding_top }}px {{ section.settings.padding_bottom }}px; } }
{%- endstyle -%}
<section class="cz-habitat-feature-row{% if section.settings.frosted_cta_style %} cz-habitat-feature-row--frosted-cta{% endif %} cz-habitat-feature-row--media-{{ section.settings.media_position }} cz-surface {{ mode_class }} {{ texture_class }} section-{{ section.id }}">
  <div class="page-width">
    <div class="cz-habitat-feature-row__inner">
      <div class="cz-habitat-feature-row__media cz-habitat-feature-row__media--{{ section.settings.media_fit }} cz-visual-media">
        {%- if section.settings.video != blank -%}
          {{ section.settings.video | video_tag: autoplay: true, loop: true, muted: true, playsinline: true, controls: false, image_size: '1600x' }}
        {%- elsif section.settings.image != blank -%}
          {{ section.settings.image | image_url: width: 1800 | image_tag: loading: 'lazy', widths: '550, 750, 1000, 1400, 1800', sizes: '(min-width: 990px) 48vw, 100vw', alt: section.settings.image_alt }}
        {%- else -%}
          {{ section.settings.placeholder | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
        {%- if section.settings.button_label != blank and section.settings.cta_position == 'media' -%}
          <a class="cz-visual-button cz-habitat-feature-row__media-cta" {% if section.settings.button_link == blank %}role="link" aria-disabled="true"{% else %}href="{{ section.settings.button_link }}"{% endif %}>{{ section.settings.button_label | escape }}</a>
        {%- endif -%}
      </div>
      <div class="cz-habitat-feature-row__content">
        {%- if section.settings.eyebrow != blank -%}<p class="cz-section-kicker">{{ section.settings.eyebrow | escape }}</p>{%- endif -%}
        {%- if section.settings.heading != blank -%}<h2 class="cz-section-heading">{{ section.settings.heading | escape }}</h2>{%- endif -%}
        {%- if section.settings.text != blank -%}<div class="cz-section-copy rte">{{ section.settings.text }}</div>{%- endif -%}
        {%- if section.settings.button_label != blank and section.settings.cta_position == 'content' -%}
          <a class="cz-visual-button" {% if section.settings.button_link == blank %}role="link" aria-disabled="true"{% else %}href="{{ section.settings.button_link }}"{% endif %}>{{ section.settings.button_label | escape }}</a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>
{% stylesheet %}
  .cz-habitat-feature-row__inner{display:grid;grid-template-columns:minmax(0,calc(.92fr * var(--cz-feature-media-scale,1))) minmax(32rem,1fr);gap:clamp(2.4rem,5vw,7rem);align-items:center}
  .cz-habitat-feature-row--media-right .cz-habitat-feature-row__media{order:2}.cz-habitat-feature-row--media-right .cz-habitat-feature-row__content{order:1}
  .cz-habitat-feature-row__media{position:relative;min-height:clamp(28rem,38vw,52rem);aspect-ratio:5/4;border:1px solid color-mix(in srgb,currentColor 18%,transparent);border-radius:8px;background:color-mix(in srgb,var(--cz-section-bg) 86%,var(--cz-section-text) 14%)}
  .cz-habitat-feature-row__media img,.cz-habitat-feature-row__media video,.cz-habitat-feature-row__media svg{width:100%;height:100%;object-fit:cover}.cz-habitat-feature-row__media--contain img,.cz-habitat-feature-row__media--contain video,.cz-habitat-feature-row__media--contain svg{object-fit:contain}
  .cz-habitat-feature-row__content{max-width:62rem}.cz-habitat-feature-row__content .cz-section-heading{font-size:clamp(3.8rem,6vw,7.6rem)}.cz-habitat-feature-row__content .cz-visual-button{margin-top:3rem}
  .cz-habitat-feature-row--frosted-cta .cz-visual-button{min-height:5.2rem;border:2px solid rgba(255,255,255,.92);border-radius:4px;padding:1.35rem 2.8rem;background:rgba(17,17,17,.38);color:#f8f7f4;box-shadow:none;-webkit-backdrop-filter:blur(6px);backdrop-filter:blur(6px);letter-spacing:.06em;line-height:1}.cz-habitat-feature-row--frosted-cta .cz-visual-button:hover,.cz-habitat-feature-row--frosted-cta .cz-visual-button:focus-visible{background:rgba(255,255,255,.22);transform:translateY(-1px)}
  .cz-habitat-feature-row__media-cta{position:absolute;right:clamp(1.6rem,3vw,3rem);bottom:clamp(1.6rem,3vw,3rem);z-index:2}
  @media screen and (max-width:989px){.cz-habitat-feature-row__inner{grid-template-columns:1fr}.cz-habitat-feature-row--media-right .cz-habitat-feature-row__media,.cz-habitat-feature-row--media-right .cz-habitat-feature-row__content{order:initial}.cz-habitat-feature-row__media{min-height:28rem;aspect-ratio:4/3}.cz-habitat-feature-row__media-cta{right:1.6rem;bottom:1.6rem}}
{% endstylesheet %}
{% schema %}
