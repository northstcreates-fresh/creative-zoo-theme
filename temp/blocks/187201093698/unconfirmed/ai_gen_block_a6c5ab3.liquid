{% doc %}
  @prompt
    A magazine-style editorial layout
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-editorial-layout-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding }}px;
  }

  .ai-editorial-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    max-width: 1400px;
    margin: 0 auto;
  }

  .ai-editorial-feature-{{ ai_gen_id }} {
    grid-column: span 8;
    position: relative;
    overflow: hidden;
  }

  .ai-editorial-feature-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    min-height: 500px;
    object-fit: cover;
    display: block;
  }

  .ai-editorial-feature-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    min-height: 500px;
    background-color: #e8e8e8;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-editorial-feature-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 400px;
    max-height: 400px;
  }

  .ai-editorial-feature-overlay-{{ ai_gen_id }} {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 40px;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.8), transparent);
    color: {{ block.settings.overlay_text_color }};
  }

  .ai-editorial-feature-category-{{ ai_gen_id }} {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 8px;
    color: {{ block.settings.accent_color }};
    font-weight: 600;
  }

  .ai-editorial-feature-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.feature_title_size }}px;
    font-weight: 700;
    line-height: 1.2;
    margin: 0 0 12px 0;
  }

  .ai-editorial-feature-excerpt-{{ ai_gen_id }} {
    font-size: 16px;
    line-height: 1.6;
    margin: 0 0 16px 0;
    opacity: 0.9;
  }

  .ai-editorial-feature-meta-{{ ai_gen_id }} {
    font-size: 14px;
    opacity: 0.8;
  }

  .ai-editorial-sidebar-{{ ai_gen_id }} {
    grid-column: span 4;
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-editorial-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    overflow: hidden;
    display: flex;
    flex-direction: column;
    border: 1px solid {{ block.settings.card_border_color }};
  }

  .ai-editorial-card-image-{{ ai_gen_id }} {
    width: 100%;
    height: 200px;
    object-fit: cover;
    display: block;
  }

  .ai-editorial-card-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 200px;
    background-color: #e8e8e8;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-editorial-card-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 150px;
    max-height: 150px;
  }

  .ai-editorial-card-content-{{ ai_gen_id }} {
    padding: 24px;
  }

  .ai-editorial-card-category-{{ ai_gen_id }} {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin-bottom: 8px;
    color: {{ block.settings.accent_color }};
    font-weight: 600;
  }

  .ai-editorial-card-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_title_size }}px;
    font-weight: 600;
    line-height: 1.3;
    margin: 0 0 8px 0;
    color: {{ block.settings.text_color }};
  }

  .ai-editorial-card-excerpt-{{ ai_gen_id }} {
    font-size: 14px;
    line-height: 1.6;
    margin: 0 0 12px 0;
    color: {{ block.settings.text_color }};
    opacity: 0.8;
  }

  .ai-editorial-card-meta-{{ ai_gen_id }} {
    font-size: 12px;
    color: {{ block.settings.text_color }};
    opacity: 0.6;
  }

  .ai-editorial-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 989px) {
    .ai-editorial-feature-{{ ai_gen_id }} {
      grid-column: span 12;
    }

    .ai-editorial-sidebar-{{ ai_gen_id }} {
      grid-column: span 12;
    }

    .ai-editorial-feature-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.feature_title_size | times: 0.7 }}px;
    }

    .ai-editorial-feature-overlay-{{ ai_gen_id }} {
      padding: 24px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-editorial-layout-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding | times: 0.5 }}px;
    }

    .ai-editorial-grid-{{ ai_gen_id }} {
      gap: {{ block.settings.grid_gap | times: 0.7 }}px;
    }

    .ai-editorial-feature-image-{{ ai_gen_id }},
    .ai-editorial-feature-placeholder-{{ ai_gen_id }} {
      min-height: 350px;
    }

    .ai-editorial-card-content-{{ ai_gen_id }} {
      padding: 16px;
    }
  }
{% endstyle %}

<div class="ai-editorial-layout-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-editorial-grid-{{ ai_gen_id }}">
    <div class="ai-editorial-feature-{{ ai_gen_id }}">
      {% if block.settings.feature_image %}
        <img
          src="{{ block.settings.feature_image | image_url: width: 1200 }}"
          alt="{{ block.settings.feature_image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.feature_image.width }}"
          height="{{ block.settings.feature_image.height }}"
          class="ai-editorial-feature-image-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-editorial-feature-placeholder-{{ ai_gen_id }}">
          {{ 'hero-apparel-1' | placeholder_svg_tag }}
          <div class="ai-editorial-empty-state-{{ ai_gen_id }}">
            Add a feature image
          </div>
        </div>
      {% endif %}

      <div class="ai-editorial-feature-overlay-{{ ai_gen_id }}">
        {% if block.settings.feature_category != blank %}
          <div class="ai-editorial-feature-category-{{ ai_gen_id }}">
            {{ block.settings.feature_category }}
          </div>
        {% endif %}

        {% if block.settings.feature_title != blank %}
          <h2 class="ai-editorial-feature-title-{{ ai_gen_id }}">
            {{ block.settings.feature_title }}
          </h2>
        {% endif %}

        {% if block.settings.feature_excerpt != blank %}
          <div class="ai-editorial-feature-excerpt-{{ ai_gen_id }}">
            {{ block.settings.feature_excerpt }}
          </div>
        {% endif %}

        {% if block.settings.feature_author != blank or block.settings.feature_date != blank %}
          <div class="ai-editorial-feature-meta-{{ ai_gen_id }}">
            {% if block.settings.feature_author != blank %}
              {{ block.settings.feature_author }}
            {% endif %}
            {% if block.settings.feature_author != blank and block.settings.feature_date != blank %}
              •
            {% endif %}
            {% if block.settings.feature_date != blank %}
              {{ block.settings.feature_date }}
            {% endif %}
          </div>
        {% endif %}
      </div>
    </div>

    <div class="ai-editorial-sidebar-{{ ai_gen_id }}">
      {% for i in (1..3) %}
        {% liquid
          assign card_image_key = 'card_' | append: i | append: '_image'
          assign card_category_key = 'card_' | append: i | append: '_category'
          assign card_title_key = 'card_' | append: i | append: '_title'
          assign card_excerpt_key = 'card_' | append: i | append: '_excerpt'
          assign card_author_key = 'card_' | append: i | append: '_author'
          assign card_date_key = 'card_' | append: i | append: '_date'

          assign card_image = block.settings[card_image_key]
          assign card_category = block.settings[card_category_key]
          assign card_title = block.settings[card_title_key]
          assign card_excerpt = block.settings[card_excerpt_key]
          assign card_author = block.settings[card_author_key]
          assign card_date = block.settings[card_date_key]
        %}

        <div class="ai-editorial-card-{{ ai_gen_id }}">
          {% if card_image %}
            <img
              src="{{ card_image | image_url: width: 600 }}"
              alt="{{ card_image.alt | escape }}"
              loading="lazy"
              width="{{ card_image.width }}"
              height="{{ card_image.height }}"
              class="ai-editorial-card-image-{{ ai_gen_id }}"
            >
          {% else %}
            <div class="ai-editorial-card-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}

          <div class="ai-editorial-card-content-{{ ai_gen_id }}">
            {% if card_category != blank %}
              <div class="ai-editorial-card-category-{{ ai_gen_id }}">
                {{ card_category }}
              </div>
            {% endif %}

            {% if card_title != blank %}
              <h3 class="ai-editorial-card-title-{{ ai_gen_id }}">
                {{ card_title }}
              </h3>
            {% endif %}

            {% if card_excerpt != blank %}
              <div class="ai-editorial-card-excerpt-{{ ai_gen_id }}">
                {{ card_excerpt }}
              </div>
            {% endif %}

            {% if card_author != blank or card_date != blank %}
              <div class="ai-editorial-card-meta-{{ ai_gen_id }}">
                {% if card_author != blank %}
                  {{ card_author }}
                {% endif %}
                {% if card_author != blank and card_date != blank %}
                  •
                {% endif %}
                {% if card_date != blank %}
                  {{ card_date }}
                {% endif %}
              </div>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

